{
  "name": "mmf-blog-api-ts",
  "version": "1.0.1",
  "packageManager": "pnpm@11.8.0",
  "description": "mmf blog api server",
  "author": "lincenying &lt;lincenying@qq.com&gt;",
  "license": "MIT",
  "engines": {
    "node": ">= 22.0.0",
    "npm": ">= 8.0.0"
  },
  "scripts": {
    "tsc": "tsc",
    "init:config": "tsx src/init.ts",
    "build": "npm run init:config && npm run tsc",
    "deploy": "node dist/app.js",
    "deploy-watch": "nodemon --delay 500ms --watch ./dist dist/app.js",
    "serve": "nodemon --watch ./src --exec tsx ./src/app.ts",
    "start": "npm run deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lincy/markdown-it-toc-and-anchor": "catalog:prod",
    "@lincy/utils": "catalog:prod",
    "axios": "catalog:prod",
    "baidu-aip-sdk": "catalog:prod",
    "base64-img": "catalog:prod",
    "cheerio": "catalog:prod",
    "compression": "catalog:prod",
    "cookie-parser": "catalog:prod",
    "dayjs": "catalog:prod",
    "express": "catalog:prod",
    "express-validator": "catalog:prod",
    "highlight.js": "catalog:prod",
    "jsonwebtoken": "catalog:prod",
    "lru-cache": "catalog:prod",
    "markdown-it": "catalog:prod",
    "markdown-it-toc-and-anchor": "catalog:prod",
    "md5": "catalog:prod",
    "mockjs": "catalog:prod",
    "mongoose": "catalog:prod",
    "mongoose-autopopulate": "catalog:prod",
    "morgan": "catalog:prod",
    "multer": "catalog:prod",
    "qiniu": "catalog:prod",
    "request-ip": "catalog:prod",
    "serve-favicon": "catalog:prod",
    "tslib": "catalog:prod",
    "twig": "catalog:prod"
  },
  "devDependencies": {
    "@lincy/eslint-config": "catalog:lint",
    "@types/compression": "catalog:types",
    "@types/cookie-parser": "catalog:types",
    "@types/express": "catalog:types",
    "@types/jsonwebtoken": "catalog:types",
    "@types/markdown-it": "catalog:types",
    "@types/md5": "catalog:types",
    "@types/mockjs": "catalog:types",
    "@types/morgan": "catalog:types",
    "@types/multer": "catalog:types",
    "@types/node": "catalog:types",
    "@types/request-ip": "catalog:types",
    "@types/serve-favicon": "catalog:types",
    "@types/supertest": "catalog:types",
    "concurrently": "catalog:dev",
    "eslint": "catalog:lint",
    "jiti": "catalog:dev",
    "nodemon": "catalog:dev",
    "supertest": "catalog:dev",
    "tsc-alias": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
